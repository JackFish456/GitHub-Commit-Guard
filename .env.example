# Copy this file to .env and fill in your API key.
# Never commit .env — add it to .gitignore.

# API key for GPT-4o
OPENAI_API_KEY=

# Optional: non-standard API base URL (e.g. custom endpoint, proxy)
OPENAI_BASE_URL=

# Optional: set to 0, false, or no to disable LLM and run local checks only
# SPEC_CHECK_USE_LLM=

# Optional: set to 0, false, or no for warning-only mode (never block; pilot rollout)
# SPEC_CHECK_ENFORCE=
